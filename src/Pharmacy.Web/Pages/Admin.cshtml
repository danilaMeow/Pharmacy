@page "/Admin"
@model Pharmacy.Web.Pages.AdminModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Панель управления</title>
    <style>
        body {
            background: #111827;
            color: #f3f4f6;
            font-family: sans-serif;
            padding: 20px;
        }

        .box {
            background: #1f2937;
            padding: 20px;
            border-radius: 8px;
            border: 1px solid #374151;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 12px;
            border-bottom: 1px solid #374151;
            text-align: left;
        }

        input {
            background: #111827;
            border: 1px solid #4b5563;
            color: white;
            padding: 8px;
            width: 100%;
            margin-bottom: 10px;
            display: block;
        }

        td input {
            margin: 0;
            display: inline;
            width: auto;
        }

        .btn {
            cursor: pointer;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            font-weight: bold;
        }

        .btn-add {
            background: #059669;
            color: white;
            width: 100%;
            padding: 10px 20px;
        }

        .btn-del {
            background: #dc2626;
            color: white;
        }

        .btn-save {
            background: #2563eb;
            color: white;
        }

        .btn-approve {
            background: #059669;
            color: white;
        }

        .btn-reject {
            background: #dc2626;
            color: white;
        }

        .badge-pending {
            background: #92400e;
            color: #fde68a;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 13px;
        }

        h3 {
            margin-top: 0;
            color: #93c5fd;
        }
    </style>
</head>
<body>
    <div style="max-width: 1200px; margin: 0 auto;">
        <h1>Админ-панель</h1>

        @if (Model != null && !string.IsNullOrEmpty(Model.Message))
        {
        <div style="padding: 15px; background: @(Model.IsError ? "#7f1d1d" : "#064e3b"); margin-bottom: 20px; border-radius: 6px;">
            @Model.Message
        </div>
        }

        @if (Model?.Medications != null)
        {
            foreach (var item in Model.Medications)
            {
        <form id="update-@item.Id" method="post" asp-page-handler="Update">
            <input type="hidden" name="Edit.Id" value="@item.Id" />
            <input type="hidden" name="Edit.Name" id="name-@item.Id" value="@item.Name" />
            <input type="hidden" name="Edit.Category" id="cat-@item.Id" value="@item.Category" />
            <input type="hidden" name="Edit.Price" id="price-@item.Id" value="@item.Price" />
            <input type="hidden" name="Edit.StockQuantity" id="qty-@item.Id" value="@item.StockQuantity" />
        </form>
        <form id="delete-@item.Id" method="post" asp-page-handler="Delete">
            <input type="hidden" name="id" value="@item.Id" />
        </form>
            }
        }

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px;">
            <div class="box">
                <h3>💊 Препараты</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Товар</th>
                            <th>Категория</th>
                            <th>Цена</th>
                            <th>Кол-во</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.Medications != null)
                        {
                            foreach (var item in Model.Medications)
                            {
                        <tr>
                            <td>
                                <input style="width:120px;"
                                       value="@item.Name"
                                       oninput="document.getElementById('name-@item.Id').value=this.value" />
                            </td>
                            <td>
                                <input style="width:120px;"
                                       value="@item.Category"
                                       oninput="document.getElementById('cat-@item.Id').value=this.value" />
                            </td>
                            <td>
                                <input type="number" step="0.01" style="width:80px;"
                                       value="@item.Price"
                                       oninput="document.getElementById('price-@item.Id').value=this.value" />
                            </td>
                            <td>
                                <input type="number" style="width:70px;"
                                       value="@item.StockQuantity"
                                       oninput="document.getElementById('qty-@item.Id').value=this.value" />
                            </td>
                            <td style="display:flex; gap:8px;">
                                <button type="submit" form="update-@item.Id" class="btn btn-save">💾</button>
                                <button type="submit" form="delete-@item.Id" class="btn btn-del">🗑</button>
                            </td>
                        </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="box">
                <h3>➕ Добавить товар</h3>
                <form method="post" asp-page-handler="Create">
                    <input type="text" asp-for="Input.Name" placeholder="Название" required />
                    <input type="text" asp-for="Input.Category" placeholder="Категория" required />
                    <input type="number" step="0.01" asp-for="Input.Price" placeholder="Цена" required />
                    <input type="number" asp-for="Input.Quantity" placeholder="Количество" required />
                    <button type="submit" class="btn btn-add">Добавить</button>
                </form>
            </div>
        </div>

        <div class="box">
            <h3>📦 Ожидающие заказы</h3>
            @if (Model?.PendingOrders != null && Model.PendingOrders.Any())
            {
            <table>
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Клиент</th>
                        <th>Товар</th>
                        <th>Кол-во</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.PendingOrders)
                        {
                    <tr>
                        <td>@order.CreatedAt.ToString("g")</td>
                        <td>@order.CustomerName</td>
                        <td>@(order.Medication?.Name ?? "—")</td>
                        <td>@order.Quantity шт.</td>
                        <td style="display:flex; gap:8px;">
                            <form method="post" asp-page-handler="Approve">
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" class="btn btn-approve">✅ Одобрить</button>
                            </form>
                            <form method="post" asp-page-handler="Reject">
                                <input type="hidden" name="id" value="@order.Id" />
                                <button type="submit" class="btn btn-reject">❌ Отклонить</button>
                            </form>
                        </td>
                    </tr>
                        }
                </tbody>
            </table>
            }
            else
            {
            <p style="color:#64748b;">Новых заказов нет.</p>
            }
        </div>

    </div>
</body>
</html>