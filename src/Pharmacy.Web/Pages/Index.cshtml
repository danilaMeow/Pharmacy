@page
@model Pharmacy.Web.Pages.IndexModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Pharmacy Shop</title>
    <style>
        body {
            background: #0f172a;
            color: #f8fafc;
            font-family: sans-serif;
            padding: 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .med-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
        }

        .med-card {
            background: #1e293b;
            padding: 20px;
            border-radius: 10px;
            border: 1px solid #334155;
        }

        .price {
            color: #fbbf24;
            font-size: 20px;
            font-weight: bold;
        }

        .btn {
            background: #10b981;
            color: white;
            border: none;
            padding: 10px;
            cursor: pointer;
            border-radius: 5px;
            width: 100%;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            border-bottom: 1px solid #334155;
            padding: 10px;
            text-align: left;
        }

        .badge-pending {
            background: #92400e;
            color: #fde68a;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 13px;
        }

        .badge-approved {
            background: #064e3b;
            color: #6ee7b7;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 13px;
        }

        .badge-rejected {
            background: #7f1d1d;
            color: #fca5a5;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 13px;
        }

        input[type=number] {
            background: #0f172a;
            border: 1px solid #4b5563;
            color: white;
            padding: 6px;
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>💊 ВитАминка | @User.Identity?.Name</h1>

        @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div style="padding:12px; background:#7f1d1d; border-radius:6px; margin-bottom:16px;">@Model.Message</div>
    }

        <div class="med-grid">
            @foreach (var med in Model.Medications)
        {
            <div class="med-card">
                <h3>@med.Name</h3>
                <p style="color:#94a3b8;">@med.Category</p>
                <div class="price">@med.Price ₽</div>
                <p>В наличии: @med.StockQuantity шт.</p>
                <form method="post" asp-page-handler="AddToCart">
                    <input type="hidden" name="CartForm.MedicationId" value="@med.Id" />
                    <input type="number" name="CartForm.Quantity" value="1" min="1"
                           max="@med.StockQuantity" style="width:60px; margin-bottom:10px;" />
                    <button type="submit" class="btn"
                            @(med.StockQuantity <= 0 ? "disabled" : "")>
                        🛒 В корзину
                    </button>
                </form>
            </div>
        }
        </div>

        <h2>📋 Мои заказы</h2>
        @if (Model.MyOrders.Any())
    {
        <table>
            <thead>
                <tr><th>Дата</th><th>Товар</th><th>Кол-во</th><th>Статус</th></tr>
            </thead>
            <tbody>
                @foreach (var order in Model.MyOrders)
                {
                <tr>
                    <td>@order.CreatedAt.ToString("g")</td>
                    <td>@(order.Medication?.Name ?? "—")</td>
                    <td>@order.Quantity шт.</td>
                    <td>
                        @if (order.Status == Pharmacy.Web.Models.OrderStatus.Pending)
                            {
                        <span class="badge-pending">⏳ Ожидает</span>
                            }
                            else if (order.Status == Pharmacy.Web.Models.OrderStatus.Approved)
                            {
                        <span class="badge-approved">✅ Одобрен</span>
                            }
                            else
                            {
                        <span class="badge-rejected">❌ Отклонён @(order.AdminComment != null ? $"— {order.AdminComment}" : "")</span>
                            }
                    </td>
                </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p style="color:#64748b;">Заказов пока нет.</p>
    }
    </div>
</body>
</html>